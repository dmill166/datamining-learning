# ──────────────────────────────────────────────────────
# Primary Dataset: NCES EDFacts (Urban Institute)
# No API key required — open REST API
# Confirmed live: 14,586 district rows for 2020 Grade 3
# ──────────────────────────────────────────────────────
NCES_GRADE3_ENDPOINT=https://educationdata.urban.org/api/v1/school-districts/edfacts/assessments/{year}/grade-{grade}/
NCES_DEFAULT_YEAR=2020
NCES_DEFAULT_GRADE=3

# ──────────────────────────────────────────────────────
# Secondary Dataset: FCC Broadband Data Collection
# Auth: username + hash_value headers (NOT a Bearer token — see Swagger spec)
# Register at: https://broadbandmap.fcc.gov
#   → Login → Profile → Manage API Access → Generate Token
# ──────────────────────────────────────────────────────
FCC_USERNAME=REPLACE_WITH_YOUR_FCC_REGISTRATION_EMAIL
FCC_HASH_VALUE=REPLACE_WITH_YOUR_FCC_BDC_HASH_VALUE
FCC_BDC_BASE_URL=https://broadbandmap.fcc.gov/api/public

# ──────────────────────────────────────────────────────
# Tertiary Dataset: Census Household Pulse Survey (HPS)
# API key optional but recommended for rate limits.
# Free key: https://api.census.gov/data/key_signup.html
# Dev mode works without any key (reads fixture file).
# ──────────────────────────────────────────────────────
CENSUS_API_KEY=REPLACE_WITH_CENSUS_API_KEY

# ──────────────────────────────────────────────────────
# Database Configuration
# ──────────────────────────────────────────────────────
DATABASE_PATH=data/education_metrics.duckdb

# ──────────────────────────────────────────────────────
# App Settings
# ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
PYTHONPATH=src
